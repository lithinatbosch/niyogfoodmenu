# Apache Configuration (Alternative to Nginx)
# Save as .htaccess in the root directory

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect to HTTPS (uncomment after SSL setup)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Handle service worker
    RewriteRule ^service-worker\.js$ service-worker.js [L]

    # Prevent access to config directory
    RewriteRule ^config/ - [F,L]

    # Prevent access to includes directory
    RewriteRule ^includes/ - [F,L]

    # Prevent access to SQL directory
    RewriteRule ^sql/ - [F,L]

    # Prevent access to hidden files
    RewriteRule ^(.*/)?\.git+ - [F,L]
    RewriteRule (^|/)\. - [F]

    # Front controller pattern
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . index.php [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # HSTS (uncomment after SSL setup)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    
    # Service Worker
    <FilesMatch "service-worker\.js$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
        Header set Service-Worker-Allowed "/"
    </FilesMatch>
    
    # Cache static assets
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|svg|webp|woff|woff2|ttf|eot|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# PHP Settings
<IfModule mod_php7.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value max_input_time 300
</IfModule>

# Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# Directory Index
DirectoryIndex index.php index.html

# Prevent directory listing
Options -Indexes

# Prevent access to specific file types
<FilesMatch "\.(sql|bak|old|backup|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>
